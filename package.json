{
  "name": "kisuke.vim",
  "version": "0.3.0",
  "description": "Vim/Neovim plugin to bring some AI features to vim. Really don't know where this is gonna go.",
  "repository": "git@github.com:dorukozerr/kisuke.vim.git",
  "author": "Doruk Özer <dorukozer@protonmail.com>",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "format": "prettier --write \"./src/**/*\"",
    "lint": "eslint --fix src",
    "type-check": "tsc --noEmit --pretty",
    "precommit": "yarn && yarn format && yarn lint && yarn type-check",
    "build": "tsup --format esm",
    "watch": "tsup src/index.ts --watch"
  },
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.7.2",
    "eslint": "^9.37.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.1",
    "@ai-sdk/mcp": "^1.0.18",
    "@ai-sdk/openai": "^3.0.25",
    "@ai-sdk/xai": "^3.0.46",
    "@langfuse/otel": "^4.5.1",
    "@langfuse/tracing": "^4.5.1",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@opentelemetry/sdk-node": "^0.211.0",
    "ai": "^6.0.3",
    "ai-sdk-ollama": "^3.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "zod": "^4.2.1"
  }
}
