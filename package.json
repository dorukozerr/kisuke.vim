{
  "name": "kisuke.vim",
  "version": "0.2.1",
  "private": false,
  "description": "Vim plugin to bring some AI features to vim. Really don't know where this is gonna go.",
  "license": "MIT",
  "author": "Doruk Özer <dorukozer@protonmail.com>",
  "repository": "git@github.com:dorukozerr/kisuke.vim.git",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node",
    "dev": "bun build src/index.ts --outfile dist/index.js --target node --watch",
    "check": "tsc --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@google/genai": "^2.2.0",
    "openai": "^6.37.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "protobufjs": "^8.0.2"
  },
  "packageManager": "bun@1.3.14"
}
